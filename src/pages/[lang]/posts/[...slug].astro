---
import { getCollection, render } from "astro:content";
import PostNavigation from "../../../components/PostNavigation.astro";
import RelatedPosts from "../../../components/RelatedPosts.astro";
import { LANGUAGES } from "../../../i18n/languages";
import Layout from "../../../layouts/Layout.astro";

const paramLang = Astro.params.lang as string;
const paramSlug = Astro.params.slug as string;

if (!LANGUAGES.includes(paramLang) || !paramSlug) {
  return Astro.rewrite("/404");
}

const posts = await getCollection("posts");
const post = posts.find((p) => {
  if (
    !p.id.endsWith(`index${paramLang}`) &&
    !p.id.endsWith(`index.${paramLang}`) &&
    !p.id.endsWith(`index.${paramLang}.md`)
  )
    return false;
  const parts = p.id.split("/");
  const slug = parts.slice(0, -1).join("/");
  return slug === paramSlug;
});

if (!post) {
  return Astro.rewrite("/404");
}

// Vercel ISR Caching Header (1 Day Cache for Posts)
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);

const { Content, headings } = await render(post);
const postTags = post.data.tags || [];
const postDate = post.data.date || "";
---

<Layout
  frontmatter={{ ...post.data, lang: paramLang }}
  headings={headings}
>
  <Content />

  <PostNavigation
    currentLang={paramLang}
    currentSlug={paramSlug}
    currentDate={postDate}
  />

  <RelatedPosts
    currentLang={paramLang}
    currentSlug={paramSlug}
    currentTags={postTags}
  />
</Layout>
