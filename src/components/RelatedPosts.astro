---
import { getCollection } from "astro:content";
import { getKstNow } from "../utils/dateUtils";
import { uiStrings } from "../utils/ui-translation";

interface Props {
  currentLang: string;
  currentSlug: string;
  currentTags?: string[];
}

const { currentLang, currentSlug, currentTags = [] } = Astro.props;
const t = uiStrings[currentLang] || uiStrings.ko;

// 1. Content Collections에서 모든 발행된 포스트 가져오기
const kstNow = getKstNow();
const allPosts = await getCollection("posts", ({ data }) => {
  return new Date(data.date) <= kstNow;
});

// 2. 현재 언어와 일치하는 포스트만 필터링
const langPosts = allPosts.filter((post) => {
  const match = post.id.match(/index\.?([a-z]{2})?\.?md$/);
  const postLang = match?.[1] ? match[1] : "ko";
  return postLang === currentLang;
});

// 3. 현재 읽고 있는 포스트는 제외
const filteredPosts = langPosts.filter((post) => {
  const parts = post.id.split("/");
  const slugBase = parts.slice(0, -1).join("/");
  return slugBase !== currentSlug;
});

// 4. 태그 교집합 기반 관련도 점수 계산
const now = Date.now();
const THIRTY_DAYS_MS = 30 * 24 * 60 * 60 * 1000;

const scoredPosts = filteredPosts.map((post) => {
  const postTags = post.data.tags || [];
  const sharedTagCount = currentTags.filter((tag) =>
    postTags.includes(tag)
  ).length;
  const isRecent =
    now - new Date(post.data.date).valueOf() < THIRTY_DAYS_MS ? 1 : 0;

  // 점수: 공유 태그 × 3 + 최근 30일 × 1
  const score = sharedTagCount * 3 + isRecent;

  return { post, score };
});

// 5. 점수순 정렬 → 동점이면 최신순 → 상위 4개
const topPosts = scoredPosts
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return (
      new Date(b.post.data.date).valueOf() -
      new Date(a.post.data.date).valueOf()
    );
  })
  .slice(0, 4);

// URL 포맷팅
const formattedPosts = topPosts.map(({ post }) => {
  const parts = post.id.split("/");
  const slugBase = parts.slice(0, -1).join("/");
  return {
    title: post.data.title,
    description: post.data.description || "",
    url: `/${currentLang}/posts/${slugBase}`,
  };
});

// "이 주제 더 보기" 링크용 첫 번째 태그
const primaryTag = currentTags.length > 0 ? currentTags[0] : null;
---

{
  formattedPosts.length > 0 && (
    <section class="related-posts-section">
      <div class="related-posts-header">{t.related_header}</div>
      <div class="related-posts-grid">
        {formattedPosts.map((post) => (
          <a href={post.url} class="related-post-card group">
            <h3 class="related-post-title">{post.title}</h3>
            <p class="related-post-desc">{post.description}</p>
          </a>
        ))}
      </div>
      {primaryTag && (
        <div class="more-topic-link">
          <a href={`/${currentLang}/tags/${primaryTag}`}>
            {t.more_topic}: #{primaryTag} →
          </a>
        </div>
      )}
    </section>
  )
}
