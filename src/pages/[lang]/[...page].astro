---
import { getCollection } from "astro:content";
import Search from "../../components/Search.astro";
import { LANGUAGES } from "../../i18n/languages";
import Layout from "../../layouts/Layout.astro";
import { formatDate, getKstNow } from "../../utils/dateUtils";

export const prerender = false;

const paramLang = Astro.params.lang as string;
const paramPage = Astro.params.page
  ? parseInt(Astro.params.page as string, 10)
  : 1;

console.log(
  `[ROUTE DEBUG] /${paramLang}/${Astro.params.page} -> parsed paramPage: ${paramPage}`,
);

if (!LANGUAGES.includes(paramLang)) {
  console.log(`[404 REASON] Invalid language: ${paramLang}`);
  return Astro.rewrite("/404");
}
if (Number.isNaN(paramPage)) {
  console.log(
    `[404 REASON] NaN paramPage from Astro.params.page: ${Astro.params.page}`,
  );
  return Astro.rewrite("/404");
}

const kstNow = getKstNow();
const allPosts = await getCollection("posts", ({ data }) => {
  return data.date <= kstNow;
});

const posts = allPosts.filter(
  (post) =>
    post.id.endsWith(`index${paramLang}`) ||
    post.id.endsWith(`index.${paramLang}`) ||
    post.id.endsWith(`index.${paramLang}.md`),
);

// === 인기 태그 계산 (빌드 타임) ===
const tagFrequency: Record<string, number> = {};
posts.forEach((post) => {
  const tags = post.data.tags || [];
  tags.forEach((tag: string) => {
    tagFrequency[tag] = (tagFrequency[tag] || 0) + 1;
  });
});

const TAG_EMOJI: Record<string, string> = {
  육아: "🧒",
  교육: "📚",
  ChatGPT: "💬",
  엑셀: "📊",
  업무효율: "💼",
  보고서: "📝",
  Midjourney: "🎨",
  "DALL-E": "🖼️",
  AI프롬프트: "🤖",
  육아꿀팁: "🍯",
  "Stable Diffusion": "✨",
  "ai-agent": "🤖",
  "prompt-engineering": "⚡",
  블로그: "✍️",
  이메일: "📧",
  코딩: "💻",
  데이터분석: "📈",
  디자인: "🎨",
  마케팅: "📣",
  SNS: "📱",
  글쓰기: "✏️",
  AI: "🧠",
};

const popularTags = Object.entries(tagFrequency)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tag]) => ({
    name: tag,
    emoji: TAG_EMOJI[tag] || "🔖",
    url: `/${paramLang}/tags/${tag}`,
  }));

const formattedPosts = posts.map((post) => {
  const parts = post.id.split("/");
  const slug = parts.slice(0, -1).join("/");
  return {
    id: post.id,
    data: post.data,
    frontmatter: post.data,
    url: `/${paramLang}/posts/${slug}`,
  };
});

const sortedPosts = formattedPosts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
);

const pageSize = 12;
const lastPage = Math.max(1, Math.ceil(sortedPosts.length / pageSize));

const start = (paramPage - 1) * pageSize;
const end = start + pageSize;
const paginatedData = sortedPosts.slice(start, end);

if (paginatedData.length === 0 && paramPage > 1) {
  console.log(
    `[404 REASON] paginatedData empty! paramPage: ${paramPage}, lastPage: ${lastPage}, posts.length: ${posts.length}`,
  );
  return Astro.rewrite("/404");
}

const page = {
  data: paginatedData,
  currentPage: paramPage,
  size: pageSize,
  lastPage: lastPage,
  url: {
    current: paramPage === 1 ? `/${paramLang}` : `/${paramLang}/${paramPage}`,
    prev:
      paramPage > 1
        ? paramPage === 2
          ? `/${paramLang}`
          : `/${paramLang}/${paramPage - 1}`
        : undefined,
    next: paramPage < lastPage ? `/${paramLang}/${paramPage + 1}` : undefined,
  },
};

const lang = paramLang;

if (paramPage === 1) {
  Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=60, stale-while-revalidate=86400",
  );
} else {
  Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=86400, stale-while-revalidate=604800",
  );
}

// 다국어 슬로건
const SLOGANS: Record<string, string> = {
  ko: "AI가 낯선 당신을 위한 가장 친절한 가이드",
  en: "The Friendliest AI Guide for Beginners",
  es: "La guía de IA más amable para principiantes",
  ja: "AI初心者のための最も親切なガイド",
  zh: "为AI初学者准备的最贴心指南",
  fr: "Le guide IA le plus convivial pour les débutants",
  de: "Der freundlichste KI-Leitfaden für Anfänger",
  pt: "O guia de IA mais amigável para iniciantes",
  ru: "Самое дружелюбное руководство по ИИ для новичков",
  it: "La guida AI più amichevole per principianti",
};

const currentSlogan =
  SLOGANS[lang as string] || "AI가 낯선 당신을 위한 가장 친절한 가이드";

const frontmatter = {
  title: "HOME",
  description: currentSlogan,
  date: new Date().toISOString().split("T")[0],
  author: "Jay & Jay",
  lang: lang as string,
};
---

<Layout frontmatter={frontmatter} isHome={true}>
  <!-- HERO -->
  <div class="hero">
    <h1 class="ai-title">HELLO PROMPT</h1>
    <div class="tech-line"></div>
    <p class="subtitle">{currentSlogan}</p>

    <!-- 검색창 추가 -->
    <Search variant="hero" />

    {/* 인기 태그 칩 */}
    {
      popularTags.length > 0 && (
        <div class="popular-tags">
          <span class="popular-tags-label">🔥 Popular Topics</span>
          {popularTags.map((tag) => (
            <a href={tag.url} class="tag-chip">
              {tag.emoji} {tag.name}
            </a>
          ))}
        </div>
      )
    }
  </div>

  <!-- POST LIST (Card Grid Style) -->
  <div class="grid-label">
    <span>LATEST INTELLIGENCE</span>
    <span class="grid-count">PAGE {page.currentPage} / {page.lastPage}</span>
  </div>

  <div class="post-grid">
    {
      page.data.map((post: any) => (
        <a href={post.url} class="post-card">
          <h2>{post.frontmatter.title}</h2>
          <p>{post.frontmatter.description}</p>
          <div class="post-meta">
            <span>
              {formatDate(post.frontmatter.date, lang as string, {
                dateOnly: true,
              })}
            </span>
            {post.frontmatter.tags &&
              post.frontmatter.tags
                .slice(0, 2)
                .map((tag: string) => <span class="tag-pill">#{tag}</span>)}
          </div>
        </a>
      ))
    }
  </div>

  <!-- 페이지네이션 컨트롤 -->
  <div class="pagination">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="nav-btn">
          &lt; PREV
        </a>
      ) : null
    }
    <span class="nav-info">{page.currentPage} / {page.lastPage}</span>
    {
      page.url.next ? (
        <a href={page.url.next} class="nav-btn">
          NEXT &gt;
        </a>
      ) : null
    }
  </div>
</Layout>
