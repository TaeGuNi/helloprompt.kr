---
import { getCollection } from "astro:content";
import BaseHtml from "../../../components/BaseHtml.astro";
import { LANGUAGES } from "../../../i18n/languages";

const paramLang = Astro.params.lang as string;
const paramTag = Astro.params.tag as string;

// Validation
if (!LANGUAGES.includes(paramLang) || !paramTag) {
  return new Response("Not found", { status: 404 });
}

const now = new Date();
const allPosts = await getCollection("posts", ({ data }) => {
  return data.date <= now;
});

// 1. Filter by language and tag
const filteredPosts = allPosts
  .filter((post) => post.id.endsWith(`index${paramLang}`))
  .filter((post) => post.data.tags?.includes(paramTag))
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf(),
  );

// 2. Map to layout props
const posts = filteredPosts.map((post) => {
  const parts = post.id.split("/");
  const slug = parts[parts.length - 2];
  return {
    id: post.id,
    frontmatter: post.data,
    url: `/${paramLang}/posts/${slug}`,
  };
});

// 3. Vercel ISR Caching Header (1 Day Cache for tags)
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=86400, stale-while-revalidate=604800",
);

const tag = paramTag;
const lang = paramLang;
---

<BaseHtml lang={lang}>
  <meta charset="utf-8" />
  <title>#{tag} | Hello Prompt ({lang})</title>
  <meta name="viewport" content="width=device-width" />
  <link
    href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Noto+Sans+KR:wght@300;500;700&family=JetBrains+Mono:wght@400&display=swap"
    rel="stylesheet"
  />
  <style>
    body {
      font-family: "Noto Sans KR", sans-serif;
      margin: 0;
      padding: 0;
      background-color: #030303;
      color: #e0e0e0;
      line-height: 1.7;
      background-image: linear-gradient(
          rgba(255, 255, 255, 0.03) 1px,
          transparent 1px
        ),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      background-position: center top;
    }
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 80px 20px;
      text-align: center;
    }

    .tag-hero {
      margin-bottom: 60px;
    }
    .tag-title {
      font-family: "Orbitron", sans-serif;
      font-size: 3rem;
      color: #00f3ff;
      text-shadow: 0 0 20px rgba(0, 243, 255, 0.5);
    }
    .tag-desc {
      color: #888;
      margin-top: 10px;
    }

    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 25px;
      text-align: left;
    }

    .post-card {
      background: rgba(10, 20, 30, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 25px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
    }
    .post-card:hover {
      transform: translateY(-5px);
      border-color: #00f3ff;
    }
    .post-card h2 {
      color: #fff;
      font-size: 1.2rem;
      margin: 0 0 10px 0;
    }
    .post-card p {
      color: #aaa;
      font-size: 0.9rem;
      flex-grow: 1;
    }
    .post-meta {
      font-size: 0.8rem;
      color: #666;
      margin-top: 15px;
      font-family: "JetBrains Mono", monospace;
    }

    .home-btn {
      display: inline-block;
      margin-top: 50px;
      color: #fff;
      text-decoration: none;
      border: 1px solid #fff;
      padding: 10px 20px;
      border-radius: 30px;
      transition: all 0.2s;
    }
    .home-btn:hover {
      background: #fff;
      color: #000;
    }
  </style>
</BaseHtml>

<div class="container">
  <div class="tag-hero">
    <h1 class="tag-title">#{tag}</h1>
    <p class="tag-desc">TAG ARCHIVE ({lang})</p>
  </div>

  <div class="post-grid">
    {
      posts.map((post: any) => (
        <a href={post.url} class="post-card">
          <h2>{post.frontmatter.title}</h2>
          <p>{post.frontmatter.description}</p>
          <div class="post-meta">
            <span>{post.frontmatter.date}</span>
          </div>
        </a>
      ))
    }
  </div>

  <a href={`/${lang}/`} class="home-btn">← RETURN HOME</a>
</div>
