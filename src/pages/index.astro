---
// This custom redirect page avoids the default white flash
// generated by Astro.redirect() in SSG mode.
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content="0;url=/ko/" />
    <link rel="canonical" href="https://helloprompt.kr/ko/" />
    <title>Hello Prompt</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #030303; /* Cyberpunk Theme Dark Background */
        color: #030303; /* Hide any default text */
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }
    </style>
    <script>
      (function () {
        // Supported languages based on src/pages/[lang]
        const supported = [
          "en",
          "de",
          "es",
          "fr",
          "it",
          "ja",
          "pt",
          "ru",
          "zh",
          "ko",
        ];
        const userLang = navigator.language || "ko";
        const shortLang = userLang.split("-")[0].toLowerCase();

        const targetLang = supported.includes(shortLang) ? shortLang : "ko";
        window.location.replace("/" + targetLang + "/");
      })();
    </script>
  </head>
  <body> </body>
</html>
