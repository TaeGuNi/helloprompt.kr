---
import { getCollection } from "astro:content";
import { getKstNow } from "../utils/dateUtils";

interface Props {
  currentLang: string;
  currentSlug: string;
}

const { currentLang, currentSlug } = Astro.props;

// 1. Content Collections에서 모든 발행된 포스트 가져오기
const kstNow = getKstNow();
const allPosts = await getCollection("posts", ({ data }) => {
  return new Date(data.date) <= kstNow;
});

// 2. 현재 언어와 일치하는 포스트만 필터링
const langPosts = allPosts.filter((post) => {
  const match = post.id.match(/index\.?([a-z]{2})?\.?md$/);
  const postLang = match && match[1] ? match[1] : "ko";
  return postLang === currentLang;
});

// 3. 현재 읽고 있는 포스트는 제외
const filteredPosts = langPosts.filter((post) => {
  const parts = post.id.split("/");
  const slugBase = parts.slice(0, -1).join("/");
  return slugBase !== currentSlug;
});

// 4. 최신순 정렬 후 상위 4개 추출
const latestPosts = filteredPosts
  .sort(
    (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
  )
  .slice(0, 4);

// URL 포맷팅
const formattedPosts = latestPosts.map((post) => {
  const parts = post.id.split("/");
  const slugBase = parts.slice(0, -1).join("/");
  return {
    title: post.data.title,
    description: post.data.description || "",
    url: `/${currentLang}/posts/${slugBase}`,
  };
});
---

{
  formattedPosts.length > 0 && (
    <section class="related-posts-section">
      <div class="related-posts-header">
        함께 보면 도움되는 강력한 프롬프트 ⚡️
      </div>
      <div class="related-posts-grid">
        {formattedPosts.map((post) => (
          <a href={post.url} class="related-post-card group">
            <h3 class="related-post-title">{post.title}</h3>
            <p class="related-post-desc">{post.description}</p>
          </a>
        ))}
      </div>
    </section>
  )
}
