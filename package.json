{
  "name": "helloprompt.kr",
  "type": "module",
  "engines": {
    "node": ">=24.13.0"
  },
  "version": "1.12.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome check .",
    "generate:trend": "tsx scripts/generate-trends.ts",
    "generate:image": "tsx scripts/generate-hook-image.ts",
    "qa": "tsx scripts/qa.ts",
    "qa:rewrite": "tsx scripts/qa-rewriter.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "release": "tsx scripts/release.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@vercel/og": "^0.8.6",
    "astro": "^5.18.0",
    "fuse.js": "^7.1.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "glob": "^13.0.1",
    "html-validate": "^10.7.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.2.7",
    "rehype-rewrite": "^4.0.4",
    "sharp": "^0.34.5",
    "standard-version": "^9.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "src/content/posts/**/*.md": [
      "pnpm qa"
    ],
    "*.{js,ts,json,cjs,mjs}": [
      "biome check --write"
    ],
    "*.{js,ts}": [
      "vitest related --run"
    ]
  }
}
