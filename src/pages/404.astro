---
import "../styles/global.css";
import RecommendedPostsPanel from "../components/RecommendedPostsPanel.astro";

// UI 번역 데이터
const uiStrings = {
  ko: { title: "404", msg: "SYSTEM ERROR: 페이지를 찾을 수 없습니다.", btn: "홈으로 복귀", rec: "추천 인텔리전스" },
  en: { title: "404", msg: "SYSTEM ERROR: Page Not Found",  btn: "RETURN HOME", rec: "RECOMMENDED INTELLIGENCE" },
  ja: { title: "404", msg: "SYSTEM ERROR: ページが見つかりません", btn: "ホームに戻る", rec: "推奨インテリジェンス" },
  zh: { title: "404", msg: "SYSTEM ERROR: 页面未找到", btn: "返回首页", rec: "推荐情报" },
  es: { title: "404", msg: "SYSTEM ERROR: Página no encontrada", btn: "VOLVER AL INICIO", rec: "INTELIGENCIA RECOMENDADA" },
  fr: { title: "404", msg: "SYSTEM ERROR: Page non trouvée", btn: "RETOUR À L'ACCUEIL", rec: "INTELLIGENCE RECOMMANDÉE" },
  de: { title: "404", msg: "SYSTEM ERROR: Seite nicht gefunden", btn: "ZURÜCK ZUR STARTSEITE", rec: "EMPFOHLENE INTELLIGENZ" },
  it: { title: "404", msg: "SYSTEM ERROR: Pagina non trovata", btn: "TORNA ALLA HOME", rec: "INTELLIGENZA RACCOMANDATA" },
  ru: { title: "404", msg: "SYSTEM ERROR: Страница не найдена", btn: "ВЕРНУТЬСЯ НА ГЛАВНУЮ", rec: "РЕКОМЕНДУЕМЫЙ ИНТЕЛЛЕКТ" },
  pt: { title: "404", msg: "SYSTEM ERROR: Página não encontrada", btn: "VOLTAR AO INÍCIO", rec: "INTELIGÊNCIA RECOMENDADA" },
};
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>404 Not Found | Hello Prompt</title>
    <meta name="viewport" content="width=device-width" />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Noto+Sans+KR:wght@400;700&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <main class="font-orbitron m-0 p-0 bg-cyber-bg text-cyber-cyan min-h-screen flex flex-col justify-center items-center text-center overflow-x-hidden pb-[50px] bg-cyber-grid-cyan">
      <h1 id="error-title" class="text-[5rem] sm:text-[8rem] m-0 [text-shadow:0_0_20px_var(--color-cyber-cyan)] animate-glitch">404</h1>
      <p id="error-msg" class="font-sans text-[1.2rem] sm:text-[1.5rem] text-[#ccc] mb-10">SYSTEM ERROR: 페이지를 찾을 수 없습니다.</p>
      <a href="/" id="error-btn" class="bg-transparent text-cyber-cyan border-2 border-cyber-cyan px-[30px] py-[15px] text-[1.2rem] no-underline font-bold transition-all duration-300 hover:bg-cyber-cyan hover:text-black hover:shadow-[0_0_30px_rgba(0,243,255,0.5)]">RETURN HOME</a>

    {/* 분리된 404 추천 컴포넌트 */}
    <RecommendedPostsPanel ui={{ rec: "RECOMMENDED INTELLIGENCE" }} />

    <script
      is:inline
      define:vars={{
        uiStrings,
      }}
    >
      (function () {
        // 1. URL에서 언어 감지
        const path = window.location.pathname;
        const segments = path.split("/").filter(Boolean);
        const firstSegment = segments[0] || "ko";

        // 지원 언어 목록 (UI 문자열 키 기반)
        const supportedLangs = Object.keys(uiStrings);
        const currentLang = supportedLangs.includes(firstSegment)
          ? firstSegment
          : "ko";
          
        document.documentElement.lang = currentLang;

        // 2. UI 텍스트 업데이트
        const ui = uiStrings[currentLang] || uiStrings["ko"];
        const titleEl = document.getElementById("error-title");
        const msgEl = document.getElementById("error-msg");
        const btnEl = document.getElementById("error-btn");
        const recTitle = document.getElementById("rec-title");

        if (titleEl) titleEl.textContent = ui.title;
        if (msgEl) msgEl.textContent = ui.msg;
        if (btnEl) {
          btnEl.textContent = ui.btn;
          btnEl.href = currentLang === "ko" ? "/" : `/${currentLang}/`;
        }
        if (recTitle) recTitle.textContent = ui.rec;

        // [Analytics] Track 404
        if (typeof window.gtag === "function") {
          window.gtag("event", "view_404", {
            event_category: "error",
            event_label: path,
            page_path: path,
          });
        }
      })();
    </script>
  </body>
</html>
