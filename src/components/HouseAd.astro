---
interface Props {
  className?: string;
  lang?: string;
}

const { className = "", lang = "ko" } = Astro.props;

// 번역 데이터 (House Ads)
const i18n = {
  ko: {
    b1: {
      title: "AI 프롬프트 마스터하기",
      desc: "초보자도 쉽게 따라하는 프롬프트 작성 가이드를 확인하세요.",
      cta: "가이드 보기",
    },
    b2: {
      title: "숨겨진 꿀팁 발견하기",
      desc: "업무 효율을 200% 높여주는 AI 활용 사례 모음",
      cta: "꿀팁 확인",
    },
    b3: {
      title: "매일 새로운 영감",
      desc: "창의적인 글쓰기와 그림을 위한 프롬프트 라이브러리",
      cta: "전체 글 보기",
    },
  },
  en: {
    b1: {
      title: "Master AI Prompts",
      desc: "Check out the easy-to-follow prompt writing guide for beginners.",
      cta: "Read Guide",
    },
    b2: {
      title: "Discover Hidden Tips",
      desc: "Collection of AI use cases that boost work efficiency by 200%.",
      cta: "Check Tips",
    },
    b3: {
      title: "Daily Inspiration",
      desc: "Prompt library for creative writing and drawing.",
      cta: "View All Posts",
    },
  },
  ja: {
    b1: {
      title: "AIプロンプトをマスターする",
      desc: "初心者でも簡単に実践できるプロンプト作成ガイドを確認してください。",
      cta: "ガイドを見る",
    },
    b2: {
      title: "隠れたヒントを発見",
      desc: "業務効率を200%向上させるAI活用事例集。",
      cta: "ヒントを確認",
    },
    b3: {
      title: "毎日の新しいインスピレーション",
      desc: "創造的な執筆や描画のためのプロンプトライブラリ。",
      cta: "すべての投稿を見る",
    },
  },
  zh: {
    b1: {
      title: "精通 AI 提示词",
      desc: "查看适合初学者的简单提示词编写指南。",
      cta: "阅读指南",
    },
    b2: {
      title: "发现隐藏技巧",
      desc: "提升 200% 工作效率的 AI 应用案例合集。",
      cta: "查看技巧",
    },
    b3: {
      title: "每日新灵感",
      desc: "用于创意写作和绘画的提示词库。",
      cta: "查看所有文章",
    },
  },
  // Default to English for others
};

// 언어 설정 (Fallback to English)
const t = i18n[lang as keyof typeof i18n] || i18n.en;

// 링크 생성 유틸리티
const getLink = (path: string) => {
  const cleanPath = path.startsWith("/") ? path : `/${path}`;
  return `/${lang}${cleanPath === "/" ? "" : cleanPath}`;
};

// 태그 링크 (언어별로 태그가 다를 수 있으나, 일단 공통 태그 'ChatGPT' 등을 활용하거나 홈으로 연결)
// 현재 시스템상 태그도 번역되어 있을 수 있으므로, 영어권에서는 영어 태그로 유도해야 함.
// 여기서는 안전하게 'ChatGPT' (공통) 또는 홈으로 유도.
// 단, 한국어는 기존대로 유지.

const getTagLink = (koreanTag: string, fallbackTag: string = "ChatGPT") => {
  // 현재 시스템상 태그도 번역되어 있을 수 있으므로, 영어권에서는 영어 태그로 유도해야 함.
  // 여기서는 안전하게 'ChatGPT' (공통) 또는 홈으로 유도.
  const tag = lang === "ko" ? koreanTag : fallbackTag;
  return `/${lang}/tags/${tag}`;
};

const banners = [
  {
    icon: "🚀",
    title: t.b1.title,
    desc: t.b1.desc,
    link: getTagLink("AI프롬프트", "ChatGPT"), // EN: /en/tags/ChatGPT
    cta: t.b1.cta,
    color: "from-blue-500/20 to-purple-500/20",
    border: "border-blue-500/30",
  },
  {
    icon: "💎",
    title: t.b2.title,
    desc: t.b2.desc,
    link: getTagLink("ChatGPT", "ChatGPT"), // EN: /en/tags/ChatGPT
    cta: t.b2.cta,
    color: "from-emerald-500/20 to-cyan-500/20",
    border: "border-emerald-500/30",
  },
  {
    icon: "✨",
    title: t.b3.title,
    desc: t.b3.desc,
    link: getLink("/"), // EN: /en/
    cta: t.b3.cta,
    color: "from-amber-500/20 to-orange-500/20",
    border: "border-amber-500/30",
  },
];

// 랜덤하게 하나 선택
const banner = banners[Math.floor(Math.random() * banners.length)];
---

<a
  href={banner.link}
  class={`group relative flex items-center justify-between w-full p-6 overflow-hidden rounded-lg border ${banner.border} bg-gradient-to-br ${banner.color} hover:opacity-90 transition-all duration-300 no-underline ${className}`}
>
  <div class="flex items-center gap-4 z-10">
    <span class="text-3xl filter drop-shadow-lg">{banner.icon}</span>
    <div class="flex flex-col">
      <span
        class="text-sm font-bold text-white group-hover:text-cyan-300 transition-colors"
      >
        {banner.title}
      </span>
      <span class="text-xs text-gray-300 mt-1 line-clamp-1">
        {banner.desc}
      </span>
    </div>
  </div>

  <div class="flex items-center z-10">
    <span
      class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider text-white bg-white/10 rounded-full border border-white/10 group-hover:bg-white/20 transition-all"
    >
      {banner.cta} &rarr;
    </span>
  </div>

  <!-- Background Effect -->
  <div
    class="absolute inset-0 bg-gradient-to-r from-transparent via-white/5 to-transparent -translate-x-full group-hover:animate-shimmer"
  >
  </div>
</a>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 1.5s infinite;
  }
</style>
