---
import "../styles/global.css";
/**
 * Main Layout Component (Shell)
 * - Refactored to use extreme componentization.
 */

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: string;
    updatedDate?: string;
    author: string;
    category?: string;
    tags?: string[];
    lang?: string;
  };
  headings?: { depth: number; slug: string; text: string }[];
  isHome?: boolean;
}

const { frontmatter, headings, isHome = false } = Astro.props;

import AdUnit from "../components/AdUnit.astro";
import Analytics from "../components/Analytics.astro";
import ArticleMeta from "../components/ArticleMeta.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import RelatedPosts from "../components/RelatedPosts.astro";
import SEO from "../components/SEO.astro";
import ShareButtons from "../components/ShareButtons.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { determineCurrentLang } from "../utils/i18nUtils";
import { uiStrings } from "../utils/ui-translation";

const currentLang = determineCurrentLang(Astro.url.pathname, frontmatter.lang);
const t = uiStrings[currentLang] || uiStrings.ko;
---

<!DOCTYPE html>
<html lang={frontmatter.lang}>
  <head>
    <meta charset="utf-8" />
    <!-- [Analytics] Google Analytics (GA4) -->
    <Analytics />
    <!-- [Ads] Google AdSense -->
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3431175239292021"
      crossorigin="anonymous"></script>
    <!-- [SEO & Meta Tags] -->
    <SEO frontmatter={frontmatter} isHome={isHome} />
  </head>
  <body>
    <div class={`container ${isHome ? "is-home" : ""}`}>
      {/* Header (Contains Nav, Breadcrumbs, LanguageSwitcher, Search) */}
      <Header isHome={isHome} currentLang={currentLang} t={t} frontmatter={frontmatter} />

      {/* --- AD: Article Top (After Header) --- */}
      {
        !isHome && (
          <AdUnit
            slotId="7945897337"
            className="container-ad-top"
            lang={currentLang}
          />
        )
      }

      {/* Table of Contents */}
      {
        !isHome && <TableOfContents headings={headings} t={t} />
      }

      {/* Main Content Area */}
      {
        isHome ? (
          <slot />
        ) : (
          <article class="prose prose-invert prose-cyan max-w-none">
            <ArticleMeta frontmatter={frontmatter} currentLang={currentLang} t={t} />
            <ShareButtons title={frontmatter.title} t={t} />

            {/* --- AD: Article Bottom (Before Comments/Related) --- */}
            <AdUnit
              slotId="8812266186"
              className="article-ad-bottom"
              lang={currentLang}
            />

            <slot />
          </article>
        )
      }

      {/* [NEW] Related Posts Component */}
      {
        !isHome && (
          <RelatedPosts
            currentTags={frontmatter.tags}
            currentPath={Astro.url.pathname}
            lang={currentLang}
          />
        )
      }

      {/* --- Footer --- */}
      <Footer currentLang={currentLang} />
    </div>

    {/* Load Interactive Prompts and UI Scripts */}
    <script src="../scripts/interactive-prompt.ts"></script>
  </body>
</html>

